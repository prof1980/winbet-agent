# === WINBET - Configurazione Ambiente ===
#
# Copia questo file in `.env` e compila con le tue credenziali:
#   cp .env.example .env
#   chmod 600 .env
#   nano .env
#
# IMPORTANTE: non committare mai il file .env su git!

# === The Odds API (https://the-odds-api.com/) ===
# Registrati gratis su https://the-odds-api.com/ — 500 crediti/mese
# Usato 1 volta/giorno per la FIFA World Cup (~2 crediti/call)
THE_ODDS_API_KEY=your_api_key_here

# === Email Libero.it (o altro provider SMTP/IMAP) ===
# Configurazione SMTP per invio report
LIBERO_EMAIL=your_email@libero.it
LIBERO_PASSWORD=your_password_here
LIBERO_SMTP_HOST=smtp.libero.it
LIBERO_SMTP_PORT=465
LIBERO_SMTP_SSL=true
# Configurazione IMAP per ricevere comandi
LIBERO_IMAP_HOST=imapmail.libero.it
LIBERO_IMAP_PORT=993

# === Telegram (opzionale, notifiche aggiuntive) ===
# Crea un bot con @BotFather su Telegram, ottieni il token
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# === Indirizzo per report giornaliero ===
# Dove vuoi ricevere il report automatico delle 8:00
DAILY_REPORT_TO=your_email@gmail.com
