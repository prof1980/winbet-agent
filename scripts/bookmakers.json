  "snai": {
    "name": "SNAI",
    "enabled": true,
    "base_url": "https://www.snai.it",
    "sport_paths": {
      "calcio": "/scommesse-sportive/calcio"
    },
    "competition_paths": {
      "serie-a": "/italia/serie-a",
      "champions-league": "/champions-league",
      "serie-b": "/italia/serie-b",
      "premier-league": "/inghilterra/premier-league",
      "la-liga": "/spagna/la-liga",
      "bundesliga": "/germania/bundesliga",
      "ligue-1": "/francia/ligue-1"
    },
    "strategies": ["api_intercept", "dom_parse"],
    "api_patterns": [
      "*/sport/*",
      "*/prematch*",
      "*/api/*",
      "*/scommesse*",
      "*odds*",
      "*quota*",
      "*event*",
      "*match*"
    ],
    "selectors": {
      "event_container": ".event-list, .events-container, [class*='event-list'], [class*='match-list']",
      "event_row": "[class*='event-row'], [class*='match-row'], [data-event-id], [class*='EventRow'], tr[class*='event']",
      "home_team": "[class*='home'], [class*='team-1'], [class*='team1'], .home-team, [class*='Home']",
      "away_team": "[class*='away'], [class*='team-2'], [class*='team2'], .away-team, [class*='Away']",
      "odds": "[class*='quota'], [class*='odds'], [class*='price'], [data-odds], [class*='Odds'], button[class*='quota']",
      "event_time": "[class*='time'], [class*='date'], [class*='ora'], time"
    },
    "anti_bot": {
      "wait_before_scrape_ms": 4000,
      "random_delay_range_ms": [800, 2500],
      "stealth_mode": true,
      "max_pages_per_session": 5
    }
  },
